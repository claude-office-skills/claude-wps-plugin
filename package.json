{
	"name": "claude-wps-plugin",
	"private": true,
	"version": "2.2.0",
	"type": "module",
	"addonType": "et",
	"scripts": {
		"dev": "vite",
		"proxy": "node proxy-server.js",
		"start": "node proxy-server.js & vite",
		"build": "tsc -b && vite build",
		"build:dist": "node build-dist.mjs",
		"lint": "eslint .",
		"preview": "vite preview",
		"test": "vitest run && npx playwright test --project=api",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:api": "npx playwright test --project=api",
		"test:e2e": "npx playwright test --project=e2e-chromium",
		"test:all": "vitest run && npx playwright test"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.78.0",
		"@lobehub/icons": "^4.6.0",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"firebase": "^12.10.0",
		"js-yaml": "^4.1.1",
		"nanoid": "^5.1.6",
		"node-cron": "^4.2.1",
		"nodemailer": "^8.0.1",
		"pdf-parse": "^2.4.5",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-markdown": "^10.1.0",
		"react-syntax-highlighter": "^16.1.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@playwright/test": "^1.58.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@vitejs/plugin-react": "^5.1.1",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"jsdom": "^28.1.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
